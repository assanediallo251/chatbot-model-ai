APP_ENV=local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_isi

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=700

EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_PRELOAD_ON_STARTUP=false

CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
MAX_UPLOAD_MB=20

ISI_OFFICIAL_URL=https://www.groupeisi.com/
ISI_CORPUS_FILTER_ENABLED=true
EXTERNAL_SEARCH_ENABLED=true
EXTERNAL_SEARCH_TIMEOUT_SECONDS=4
EXTERNAL_SEARCH_TOTAL_TIMEOUT_SECONDS=12
EXTERNAL_SEARCH_MAX_PAGES=5
EXTERNAL_SEARCH_MAX_SOURCES=4
EXTERNAL_SEARCH_MIN_SCORE=0.12
EXTERNAL_SEARCH_SEED_URLS=https://www.groupeisi.com/,https://siege.groupeisi.com/paiement/,https://siege.groupeisi.com/administration/,https://siege.groupeisi.com/mot-du-pdg/,https://www.groupeisi.com/?page_id=47335,https://www.groupeisi.com/?page_id=25185,https://www.groupeisi.com/?page_id=50350
EXTERNAL_SEARCH_ALLOWED_DOMAINS=groupeisi.com,siege.groupeisi.com,elearning-groupeisi.com,test.groupeisi.com,isikeurmassar.com,isisuptech.com,ziguinchor.groupeisi.com,diourbel.groupeisi.com,cfegroupeisi.com

CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
